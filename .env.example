# Sports API
# Base URL for the sports data API
VITE_API_BASE_URL=https://api.sportsdata.example.com/v1

# API Key for authentication (if required)
VITE_API_KEY=your_api_key_here

# Request timeout in milliseconds
VITE_API_TIMEOUT=15000

# App
# Application name displayed in the UI
VITE_APP_NAME=Sports Dashboard

# Enable debug logging (true/false)
VITE_DEBUG=false

# Feature flags
# Enable live score polling (true/false)
VITE_ENABLE_LIVE_SCORES=true

# Live scores polling interval in milliseconds
VITE_LIVE_POLL_INTERVAL=30000
